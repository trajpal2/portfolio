# Public site URL (no trailing slash) — used for SEO, Open Graph, sitemap
NEXT_PUBLIC_SITE_URL=https://trajpal2.github.io/portfolio

# GitHub Pages project site — required so /assets/... resolves under /portfolio
NEXT_PUBLIC_BASE_PATH=/portfolio

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
# Sender shown in the inbox (display name + address)
MAIL_FROM="Notification From Portfolio <your-email@gmail.com>"
# Inbox that receives contact form submissions; Reply-To is the visitor's email from the form
CONTACT_EMAIL=tushant.rajpal23@gmail.com

# Optional: long random string — GET /api/resume-downloads?secret=YOUR_VALUE returns JSON counters
# (resumeDownloads, visits, contactSubmissions) from data/site-stats.json
STATS_SECRET=
